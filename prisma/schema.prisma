// ============================================================
// Prisma Schema — Expense Tracker
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  owner
  member
}

enum AccountType {
  bank
  cash
  credit_card
  savings
}

enum TransactionType {
  expense
  income
  transfer
}

enum Frequency {
  daily
  weekly
  monthly
  yearly
}

enum BudgetPeriod {
  monthly
  yearly
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
}

// ============================================================
// USERS
// ============================================================

model User {
  id              String    @id 
  email           String    @unique
  name            String?
  avatarUrl       String?
  defaultCurrency String    @default("EUR") @db.Char(3)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // soft delete

  // Relations
  householdMembers    HouseholdMember[]
  accounts            Account[]
  transactions        Transaction[]
  recurringTransactions RecurringTransaction[]
  createdHouseholds   Household[]            @relation("HouseholdCreator")
  notifications       Notification[]
  sentInvitations     Invitation[]           @relation("SentInvitations")

  @@map("users")
}

// ============================================================
// HOUSEHOLDS
// ============================================================

model Household {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  // Relations
  creator              User                   @relation("HouseholdCreator", fields: [createdBy], references: [id])
  members              HouseholdMember[]
  accounts             Account[]
  categories           Category[]
  tags                 Tag[]
  transactions         Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets              Budget[]
  invitations          Invitation[]

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(uuid())
  householdId String
  userId      String
  role        Role     @default(member)
  joinedAt    DateTime @default(now())

  // Relations
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model Invitation {
  id          String           @id @default(uuid())
  token       String           @unique @default(uuid())
  householdId String
  invitedBy   String
  email       String?
  status      InvitationStatus @default(pending)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inviter   User      @relation("SentInvitations", fields: [invitedBy], references: [id])

  @@index([token])
  @@index([householdId])
  @@index([email])
  @@map("invitations")
}

// ============================================================
// ACCOUNTS (wallets)
// ============================================================

model Account {
  id          String      @id @default(uuid())
  userId      String
  householdId String?     // nullable — shared household account
  name        String
  type        AccountType
  currency    String      @db.Char(3)
  balance     Decimal     @default(0) @db.Decimal(15, 2)
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?   // soft delete

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  household    Household?    @relation(fields: [householdId], references: [id])
  transactions Transaction[]
  recurringTransactions RecurringTransaction[]

  @@map("accounts")
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id          String    @id @default(uuid())
  householdId String?   // null = system default category
  name        String
  icon        String?   // emoji or icon name
  color       String?   // hex color
  isIncome    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // Relations
  household             Household?             @relation(fields: [householdId], references: [id])
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@map("categories")
}

// ============================================================
// TAGS
// ============================================================

model Tag {
  id          String @id @default(uuid())
  householdId String
  name        String

  // Relations
  household    Household        @relation(fields: [householdId], references: [id])
  transactions TransactionTag[]

  @@unique([householdId, name])
  @@map("tags")
}

// ============================================================
// TRANSACTIONS
// ============================================================

model Transaction {
  id            String          @id @default(uuid())
  householdId   String
  accountId     String?
  userId        String
  categoryId    String?
  recurringId   String?         // if spawned from a recurring rule

  amount        Decimal         @db.Decimal(15, 2)
  currency      String          @db.Char(3)
  amountBase    Decimal?        @db.Decimal(15, 2)  // converted to household base currency
  exchangeRate  Decimal?        @db.Decimal(15, 6)  // rate used at time of entry

  type          TransactionType @default(expense)
  description   String?
  date          DateTime        @db.Date            // user-chosen date
  notes         String?
  receiptUrl    String?         // single receipt — extend to TransactionAttachment later

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?       // soft delete

  // Relations
  household   Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account     Account?             @relation(fields: [accountId], references: [id])
  user        User                 @relation(fields: [userId], references: [id])
  category    Category?            @relation(fields: [categoryId], references: [id])
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  tags        TransactionTag[]

  @@index([householdId, date])
  @@index([userId, date])
  @@index([categoryId])
  @@index([accountId])
  @@map("transactions")
}

model TransactionTag {
  transactionId String
  tagId         String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

// ============================================================
// RECURRING TRANSACTIONS
// ============================================================

model RecurringTransaction {
  id          String    @id @default(uuid())
  householdId String
  accountId   String?
  userId      String
  categoryId  String?

  amount      Decimal   @db.Decimal(15, 2)
  currency    String    @db.Char(3)
  description String
  type        TransactionType @default(expense)

  frequency   Frequency
  interval    Int       @default(1)  // every N frequency units e.g. every 2 weeks
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date     // null = runs forever
  nextDueDate DateTime  @db.Date     // cron job queries this

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account      Account?      @relation(fields: [accountId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([nextDueDate, isActive]) // cron job index
  @@map("recurring_transactions")
}

// ============================================================
// BUDGETS
// ============================================================

model Budget {
  id          String       @id @default(uuid())
  householdId String
  categoryId  String?      // null = overall household budget
  amount      Decimal      @db.Decimal(15, 2)
  currency    String       @db.Char(3)
  period      BudgetPeriod
  startDate   DateTime     @db.Date
  endDate     DateTime?    @db.Date
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])

  @@map("budgets")
}

// ============================================================
// CURRENCIES & EXCHANGE RATES
// ============================================================

model Currency {
  code   String @id @db.Char(3)  // ISO 4217 e.g. 'EUR', 'USD'
  name   String
  symbol String

  @@map("currencies")
}

model ExchangeRate {
  id            String   @id @default(uuid())
  baseCurrency  String   @db.Char(3)
  quoteCurrency String   @db.Char(3)
  rate          Decimal  @db.Decimal(15, 6)
  date          DateTime @db.Date

  @@unique([baseCurrency, quoteCurrency, date])
  @@index([date])
  @@map("exchange_rates")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String    // 'budget_alert' | 'recurring_due' | 'general'
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
